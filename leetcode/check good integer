class Solution:
    def checkGoodInteger(self, n: int) -> bool:
        digit_sum = 0
        square_sum = 0

        # Process each digit of the number
        while n > 0:
            digit = n % 10
            digit_sum += digit
            square_sum += digit**2
            n //= 10

        # Check if it meets the criteria
        return (square_sum - digit_sum) >= 50
