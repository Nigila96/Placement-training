def shortest_repunit(d: int) -> int:
    remainder = 0
    for length in range(1, d + 1):
        remainder = (remainder * 10 + 1) % d
        if remainder == 0:
            return length
    return -1

try:
    divisor = int(input("Enter a divisor ending with 3: "))
    if divisor % 10 != 3:
        print("Error: The number must end with the digit 3.")
    else:
        length = shortest_repunit(divisor)
        print(f"The shortest repunit length divisible by {divisor} is: {length}")
except ValueError:
    print("Invalid input. Please enter a valid integer.")
