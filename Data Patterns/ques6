import math

def isPrime(n):

    if n < 2:
        return False

    for i in range(2, int(math.sqrt(n)) + 1):
        if n % i == 0:
            return False

    return True


x = int(input("Enter a number: "))

num = x + 1

while True:
    if isPrime(num):
        print("Next Prime =", num)
        break

    num += 1
